---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daily digests of physics and mathematics discoveries that move humanity forward.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,650&family=Sora:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="atmosphere" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/">Forward</a>
      <p class="brand-mark">Physics &amp; Maths</p>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Daily research digests · source of truth in the repo</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink: #0f1c24;
    --ink-soft: #243540;
    --paper: #e8eef2;
    --paper-dim: #c5d0d8;
    --mist: rgba(232, 238, 242, 0.08);
    --accent: #2a9d8f;
    --accent-glow: rgba(42, 157, 143, 0.35);
    --font-display: 'Fraunces', 'Georgia', serif;
    --font-body: 'Sora', 'Helvetica Neue', sans-serif;
    --max: 42rem;
  }

  * {
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--paper);
    background: var(--ink);
    position: relative;
  }

  .atmosphere {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 50% at 10% -10%, var(--accent-glow), transparent 55%),
      radial-gradient(ellipse 60% 40% at 90% 10%, rgba(90, 140, 180, 0.22), transparent 50%),
      linear-gradient(165deg, #0a141a 0%, var(--ink) 45%, #132028 100%);
    animation: drift 18s ease-in-out infinite alternate;
  }

  @keyframes drift {
    from {
      filter: hue-rotate(0deg);
      transform: scale(1);
    }
    to {
      filter: hue-rotate(12deg);
      transform: scale(1.03);
    }
  }

  a {
    color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: #5ecfc0;
  }

  .site-header {
    max-width: calc(var(--max) + 4rem);
    margin: 0 auto;
    padding: 1.75rem 1.5rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    animation: rise 0.7s ease-out both;
  }

  .brand {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 650;
    color: var(--paper);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .brand:hover {
    color: var(--paper);
  }

  .brand-mark {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--paper-dim);
  }

  main {
    max-width: calc(var(--max) + 4rem);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
    animation: rise 0.85s ease-out 0.08s both;
  }

  .site-footer {
    max-width: calc(var(--max) + 4rem);
    margin: 0 auto;
    padding: 0 1.5rem 2.5rem;
    color: var(--paper-dim);
    font-size: 0.85rem;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(0.75rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .prose h1,
  .prose h2,
  .prose h3 {
    font-family: var(--font-display);
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--paper);
  }

  .prose h1 {
    font-size: clamp(1.85rem, 4vw, 2.4rem);
    margin: 0 0 1rem;
  }

  .prose h2 {
    font-size: 1.35rem;
    margin: 2.25rem 0 0.85rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--mist);
  }

  .prose h3 {
    font-size: 1.15rem;
    margin: 1.75rem 0 0.5rem;
  }

  .prose p,
  .prose li {
    color: var(--paper-dim);
  }

  .prose strong {
    color: var(--paper);
    font-weight: 600;
  }

  .prose ul {
    padding-left: 1.2rem;
  }

  .lede {
    font-size: 1.15rem;
    color: var(--paper-dim);
    margin: 0 0 2rem;
    max-width: 36rem;
  }

  .digest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .digest-list a {
    display: block;
    color: inherit;
    text-decoration: none;
    padding: 0.35rem 0;
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .digest-list a:hover {
    border-bottom-color: var(--accent);
    transform: translateX(0.25rem);
  }

  .digest-list time {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .digest-list h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 650;
    margin: 0 0 0.4rem;
    color: var(--paper);
  }

  .digest-list p {
    margin: 0;
    color: var(--paper-dim);
    font-size: 0.98rem;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    margin: 0 0 1.75rem;
    font-size: 0.85rem;
    color: var(--paper-dim);
  }

  .meta-row a {
    font-weight: 500;
  }

  .empty {
    color: var(--paper-dim);
  }
</style>
